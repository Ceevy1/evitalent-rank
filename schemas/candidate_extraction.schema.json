{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evitalent.local/schemas/candidate_extraction.schema.json",
  "title": "EviTalent Candidate Extraction",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "candidate_id",
    "parse_metadata",
    "sensitive_information",
    "candidate_profile",
    "education_records",
    "career_records",
    "project_records",
    "achievement_events",
    "domain_assessment_inputs",
    "evidence_items",
    "quality_flags",
    "llm_metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "minLength": 1},
    "document_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "parse_metadata": {
      "type": "object",
      "required": ["source_type", "parsed_at", "parser_version"],
      "properties": {
        "source_type": {"type": "string"},
        "parsed_at": {"type": "string"},
        "parser_version": {"type": "string"},
        "redacted_text_path": {"type": ["string", "null"]},
        "source_filename": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "sensitive_information": {
      "type": "object",
      "required": [
        "name_detected",
        "gender",
        "birth_year",
        "marital_status",
        "salary_current",
        "salary_expected",
        "location",
        "masked_for_scoring"
      ],
      "properties": {
        "name_detected": {"type": "boolean"},
        "gender": {"type": ["string", "null"]},
        "birth_year": {"type": ["integer", "null"], "minimum": 1900, "maximum": 2100},
        "marital_status": {"type": ["string", "null"]},
        "salary_current": {"type": ["string", "null"]},
        "salary_expected": {"type": ["string", "null"]},
        "location": {"type": ["string", "null"]},
        "masked_for_scoring": {"const": true}
      },
      "additionalProperties": true
    },
    "candidate_profile": {
      "type": "object",
      "required": ["display_id", "target_domain_candidates", "summary"],
      "properties": {
        "display_id": {"type": "string"},
        "target_domains": {"type": "array", "items": {"type": "string"}},
        "target_domain_candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["domain", "confidence", "evidence_ids"],
            "properties": {
              "domain": {"type": "string"},
              "confidence": {"type": "number", "minimum": 0, "maximum": 1},
              "evidence_ids": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          }
        },
        "summary": {"type": "string"},
        "highest_degree": {"type": ["string", "null"]},
        "major": {"type": ["string", "null"]},
        "total_years_experience": {"type": ["number", "null"]},
        "current_level": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "education_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["school", "degree", "major", "start_date", "end_date", "evidence_id"],
        "properties": {
          "school": {"type": "string"},
          "degree": {"type": "string"},
          "major": {"type": "string"},
          "start_date": {"type": ["string", "null"]},
          "end_date": {"type": ["string", "null"]},
          "evidence_id": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "career_records": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["company", "title", "start_date", "end_date", "description", "evidence_ids"],
        "properties": {
          "company": {"type": "string"},
          "title": {"type": "string"},
          "start_date": {"type": ["string", "null"]},
          "end_date": {"type": ["string", "null"]},
          "description": {"type": "string"},
          "domain_tags": {"type": "array", "items": {"type": "string"}},
          "management_headcount": {"type": ["integer", "null"], "minimum": 0},
          "platform_evidence": {"type": "array", "items": {"type": "string"}},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "evidence_id": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "project_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["project_name", "start_date", "end_date", "description", "evidence_ids"],
        "properties": {
          "project_name": {"type": "string"},
          "start_date": {"type": ["string", "null"]},
          "end_date": {"type": ["string", "null"]},
          "description": {"type": "string"},
          "domain_tags": {"type": "array", "items": {"type": "string"}},
          "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "evidence_id": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "achievement_events": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/achievement_event"}
    },
    "domain_assessment_inputs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["domain", "matched_tags", "competency_tags", "evidence_ids"],
        "properties": {
          "domain": {"type": "string"},
          "matched_tags": {"type": "array", "items": {"type": "string"}},
          "competency_tags": {"type": "array", "items": {"type": "string"}},
          "collaboration_tags": {"type": "array", "items": {"type": "string"}},
          "evidence_ids": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "evidence_items": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["evidence_id", "section", "quote", "fact_type", "used_for_scoring"],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "section": {"type": "string"},
          "quote": {"type": "string", "minLength": 1},
          "fact_type": {"type": "string"},
          "used_for_scoring": {"type": "boolean"},
          "page_number": {"type": ["integer", "null"]},
          "char_start": {"type": ["integer", "null"]},
          "char_end": {"type": ["integer", "null"]}
        },
        "additionalProperties": true
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flag_type", "severity", "description", "related_evidence_ids"],
        "properties": {
          "flag_type": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warning", "error"]},
          "description": {"type": "string"},
          "related_evidence_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "llm_metadata": {
      "type": "object",
      "required": ["provider", "model_name", "temperature"],
      "properties": {
        "provider": {"type": "string"},
        "model_name": {"type": "string"},
        "temperature": {"type": "number"},
        "extracted_at": {"type": ["string", "null"]},
        "mode": {"type": "string"},
        "model": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "achievement_event": {
      "type": "object",
      "required": [
        "achievement_id",
        "event_type",
        "metric_name",
        "metric_value",
        "metric_value_upper",
        "unit",
        "direction",
        "period_months",
        "approximate",
        "lower_bound",
        "candidate_contribution",
        "evidence_grade",
        "evidence_id"
      ],
      "properties": {
        "achievement_id": {"type": "string", "minLength": 1},
        "event_type": {
          "type": "string",
          "enum": [
            "revenue_growth",
            "gmv_growth",
            "roi_improvement",
            "conversion_improvement",
            "cost_reduction",
            "efficiency_improvement",
            "loss_reduction",
            "quality_improvement",
            "recruitment_delivery",
            "recruitment_completion_rate",
            "retention_improvement",
            "organization_transformation",
            "product_launch",
            "automation_upgrade",
            "promotion_award",
            "patent_publication",
            "technology_transfer",
            "collection_performance",
            "channel_expansion",
            "other"
          ]
        },
        "metric_name": {"type": "string"},
        "metric_value": {"type": ["number", "null"]},
        "metric_value_upper": {"type": ["number", "null"]},
        "unit": {"type": ["string", "null"]},
        "direction": {"type": "string", "enum": ["increase_by", "decrease_by", "achieved_level", "achieved_amount", "maintained", "unknown", "increase", "decrease", "maintain", "launch", "other"]},
        "period_months": {"type": ["integer", "null"], "minimum": 0},
        "approximate": {"type": "boolean"},
        "lower_bound": {"type": "boolean"},
        "candidate_contribution": {"type": "string"},
        "evidence_grade": {"type": "string", "enum": ["A", "B", "C", "D"]},
        "evidence_id": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    }
  }
}
